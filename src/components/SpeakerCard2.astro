---
import { FaLinkedin, FaGlobe } from "react-icons/fa";
// import { Icon } from "astro-icon/components"; // ei toimi jos pelkästään importtaa

interface Props {
  name: string;
  title: string;
  image: string;
  company?: string;
  linkedin?: string;
  website?: string;
}

const { name, title, image, company, linkedin, website } = Astro.props;

---
<div class="bg-container min-h-[650px] sm:min-h-[710px] flex flex-col w-full h-full rounded-lg overflow-hidden shadow-root-card">
  <div class="relative w-full">
    <div class="aspect-square grayscale">
      <img src={image} class="w-full h-full object-cover" />
    </div>
  </div>

  <div class="px-4 py-6 space-y-3">
    <h2 class="text-4xl leading-tight">{name}</h2>
    <h5 class="text-accent text-3xl">{title}</h5>

    <div class="flex justify-between items-center pb-2 text-md sm:text-lg">
      {company && (
        <p class="leading-relaxed text-md sm:text-lg font-jetbrains">{company}</p>
      )}
      <div class="flex items-center gap-6 pr-4">
      {
        linkedin && (
          <div class="flex items-center gap-2">
        <a
          href={linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-white truncate"
        >
          <FaLinkedin className="text-accent flex-shrink-0" size={40} />
        </a>
      </div>
    )
  }
  {
        website && (
          <div class="flex items-center gap-2">
        <a
          href={website}
          target="_blank"
          rel="noopener noreferrer"
          class="text-white truncate"
        >
          <FaGlobe className="text-accent flex-shrink-0" size={40} />
        </a>
      </div>
    )
  }

    </div>
    </div>
  </div>
</div>
