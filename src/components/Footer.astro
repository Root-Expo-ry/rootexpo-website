---
import SocialsLink from "./SocialsLink.astro";

const today = new Date();
---

<footer
  class="py-8 px-4 pb-24 bg-gradient-to-b from-gray-200 via-gray-300 to-gray-400 text-gray-700 text-center"
>
  &copy; {today.getFullYear()} Root Expo. All rights reserved.
  <div class="social-links flex justify-center gap-4 mt-4">
    <SocialsLink />
  </div>
</footer>
