---
import Body from "../components/Body.astro";
import Content from "../components/Content.astro";
import Pricing from "../components/Pricing.astro";
import SubTitle from "../components/SubTitle.astro";
import Title from "../components/Title.astro";
import Layout from "../layouts/BaseLayout.astro";
---

<Layout
  title="For Partners"
  description="What value do we bring for the partners and employers?"
>
  <Content>
    <Title text="FOR PARTNERS" />
    <Body
      text=`We aim to become the largest meeting point for IT talent and employers in the region, attracting a relevant and enthusiastic audience. Students will have a unique chance to learn about the future of IT through inspiring talks and get helpful tips for job applications directly from you.`
    />
    <Body
      text=`For companies, this event offers great visibility and a chance to meet promising future professionals. We also warmly welcome international talent, providing everyone with a comfortable space to network, be themselves, and create meaningful connections.`
    />
    <SubTitle text="What you get?" />
    <Body
      text=`1. Exhibition stand at the epic venue
Choose your setup and make it yours—we provide the space, you bring the vibe.`
    />
    <Body
      text=`2. Customized visibility across all key channels
We’ll spotlight your brand on social media with customized content—company intros, ads, and more to make sure you get noticed before, during, and after the event.
`
    />
    <Body
      text=`3. 100% focus on IT.
No distractions—just curious students and companies that speak the same language.
`
    />
    <Title text="PRICING" />
    <Pricing />
  </Content>
</Layout>
